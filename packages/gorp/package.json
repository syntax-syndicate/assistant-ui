{
  "name": "@assistant-ui/gorp",
  "version": "0.0.1",
  "description": "State-sync primitive: client/server replicas with optimistic updates over a tiny wire protocol",
  "keywords": [
    "state-sync",
    "optimistic",
    "transport-agnostic",
    "assistant-ui"
  ],
  "author": "AgentbaseAI Inc.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "aui-build",
    "prepublishOnly": "pnpm turbo build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@assistant-ui/x-buildutils": "workspace:*",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://www.assistant-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/assistant-ui.git",
    "directory": "packages/gorp"
  },
  "bugs": {
    "url": "https://github.com/assistant-ui/assistant-ui/issues"
  }
}
