{
  "name": "@assistant-ui/metro",
  "version": "0.0.4",
  "description": "Metro / Expo integration for assistant-ui: the \"use generative\" directive compiler that colocates a tool's schema, server execute, and client render in one file. Works with Expo and bare React Native.",
  "keywords": [
    "assistant-ui",
    "metro",
    "expo",
    "react-native",
    "generative",
    "use generative",
    "babel-transformer"
  ],
  "author": "AgentbaseAI Inc.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "./transformer": {
      "types": "./dist/transformer.d.cts",
      "default": "./dist/transformer.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0"
  },
  "devDependencies": {
    "@assistant-ui/x-buildutils": "workspace:*",
    "@assistant-ui/x-generative-compiler": "workspace:^",
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://www.assistant-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/assistant-ui.git",
    "directory": "packages/metro"
  },
  "bugs": {
    "url": "https://github.com/assistant-ui/assistant-ui/issues"
  }
}
