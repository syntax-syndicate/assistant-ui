{
  "name": "@assistant-ui/react-google-adk",
  "version": "0.0.15",
  "description": "Google ADK adapter for assistant-ui",
  "keywords": [
    "google-adk",
    "adk",
    "assistant-ui",
    "react",
    "ai",
    "chat",
    "agents"
  ],
  "author": "AgentbaseAI Inc.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "server",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "aui-build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@assistant-ui/core": "^0.2.16",
    "@assistant-ui/store": "^0.2.18",
    "assistant-cloud": "*",
    "assistant-stream": "^0.3.23",
    "uuid": "^14.0.0"
  },
  "peerDependencies": {
    "@google/adk": ">=0.5.0",
    "@types/react": "*",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@google/adk": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@assistant-ui/x-buildutils": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/uuid": "^11.0.0",
    "react": "^19.2.7",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://www.assistant-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/assistant-ui.git",
    "directory": "packages/react-google-adk"
  },
  "bugs": {
    "url": "https://github.com/assistant-ui/assistant-ui/issues"
  }
}
